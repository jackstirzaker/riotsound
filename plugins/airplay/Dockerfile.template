FROM mikebrady/shairport-sync:5.0.1
WORKDIR /usr/src

ENV DBUS_SYSTEM_BUS_ADDRESS=unix:path=/host/run/dbus/system_bus_socket
# Audio block exposes pipewire-pulse compat on host port 4317
# airplay runs network_mode:host so localhost:4317 is correct
ENV PULSE_SERVER=tcp:localhost:4317

RUN apk update && apk add --no-cache supervisor

COPY start.sh /usr/src/
COPY supervisor.conf /usr/src/supervisor.conf

# shairport-sync image entrypoint starts dbus and avahi — we manage those via supervisor
ENTRYPOINT []
CMD ["supervisord", "-c", "/usr/src/supervisor.conf"]
